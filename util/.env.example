# hyperion-util — environment configuration
#
# Copy to `.env` and fill in values. Variables map 1:1 to ${VAR} placeholders
# in config.ini. The util is one-shot: it bootstraps the engine then exits.
#
# Two deployment modes:
#   DEPLOYMENT_TYPE=local + CLOUD_STORAGE=local   — local demo (MinIO + HAPI)
#   DEPLOYMENT_TYPE=azure + CLOUD_STORAGE=azure   — Azure (ADLS + Azure FHIR)

# === Logging =========================================================
# INFO | DEBUG | ERROR
LOG_LEVEL=INFO

# === Deployment selector ===========================================
# local | azure
DEPLOYMENT_TYPE=local
# used when DEPLOYMENT_TYPE=azure
FHIR_SERVICE=azure
# local | azure
CLOUD_STORAGE=local

# === Audit / lineage =================================================
IS_AUDIT=true
IS_LINEAGE=true

# === Local FHIR (HAPI) — when DEPLOYMENT_TYPE=local ==================
FHIR_SERVER_URL=http://localhost:8080/fhir
LOCAL_FHIR_SERVER_TIMEOUT_SECONDS=30

# === Azure FHIR — when DEPLOYMENT_TYPE=azure =========================
AZURE_FHIR_SERVER_BASEURL=
AZURE_FHIR_SERVER_CLIENT_ID=
AZURE_FHIR_SERVER_CLIENT_SECRET=
AZURE_FHIR_SERVER_SCOPE=
AZURE_FHIR_SERVER_GRANT_TYPE=client_credentials
AZURE_FHIR_SERVER_TOKEN_URL=
AZURE_FHIR_SERVER_TIMEOUT_SECONDS=60

# === Local object storage (MinIO over S3 API) — when CLOUD_STORAGE=local
LOCAL_STORAGE_ENDPOINT=http://localhost:9000
LOCAL_STORAGE_LOCATIONS=s3://hyperion/
LOCAL_STORAGE_ACCESS_KEY_ID=minioadmin
LOCAL_STORAGE_ACCESS_KEY_SECRET=minioadmin123
LOCAL_STORAGE_REGION=us-east-1

# === Azure Blob / ADLS — when CLOUD_STORAGE=azure ====================
# These point at the cloud storage that backs StarRocks shared-data tables.
# This may be a different storage account than the FHIR NDJSON staging
# account (which the core service uses via AZURE_STORAGE_*).
AZURE_BLOB_STORAGE_SILVER_LAYER_CONTAINER=
# IMPORTANT — endpoint suffix MUST match AZURE_BLOB_STORAGE_VERSION:
#   • version=1 (AZBLOB / gen1):    https://<account>.blob.core.windows.net
#   • version=2 (ADLS Gen2):        https://<account>.dfs.core.windows.net
# A mismatch causes silent CREATE TABLE failure with
# "Invalid adls2.endpoint configuration provided!" from the BE/CN.
AZURE_BLOB_STORAGE_END_POINT=
# 1 = AZBLOB (blob storage / gen1), 2 = ADLS Gen2 (hierarchical namespace)
AZURE_BLOB_STORAGE_VERSION=2
# Shared key for the storage account that holds engine table data.
# Azure Portal → Storage account → Access keys → key1.
AZURE_BLOB_STORAGE_ACCOUNT_KEY=

# === Hyperion engine (StarRocks) =====================================
SILVER_LAYER_ROOT_USERNAME=root
SILVER_LAYER_ROOT_PASSWORD=
SILVER_LAYER_QUERY_SERVER=starrocks-fe:9030
SILVER_LAYER_CATALOG=default_catalog
SILVER_LAYER_CORE_DATABASE=_hyperion_core_
SILVER_LAYER_AUDIT_DATABASE=_hyperion_audit_
SILVER_LAYER_REPLICA=1
SILVER_LAYER_STORAGE_VOLUME=hyperion_storage_volume

# === Schema generation ===============================================
SCHEMA_OVERWRITE_FLAG=true
DATABASE_INITIALIZATION_FLAG=true

# === Service-account user (used by hyperion-core at runtime) =========
SERVICE_ACCOUNT_USERNAME=hyperion_service
SERVICE_ACCOUNT_PASSWORD=
