# hyperion-core — environment template
#
# Copy this file to `.env` and fill in values for the mode you're running in.
# `.env` is gitignored — never commit secrets.
#
# Defaults below assume local mode (HAPI FHIR + the engine via docker-compose).
# Set CLOUD_STORAGE / SERVICEBUS / FHIR_SERVICE to "azure" and uncomment the
# Azure block to run against Azure FHIR + Service Bus + Blob Storage.

# ---- Application dispatch ----
# Which module this container runs (see README "Modules" section).
APPLICATION_NAME=core-data-ingester
LOG_LEVEL=INFO

# ---- Cloud provider switches (per service; "azure" or "local") ----
CLOUD_STORAGE=local
SERVICEBUS=local
FHIR_SERVICE=local

# ---- Hyperion Engine ----
SILVER_LAYER_QUERY_SERVER=starrocks-fe:9030
SILVER_LAYER_HTTP_SERVER=starrocks-fe:8030
SILVER_LAYER_CATALOG=default_catalog
SILVER_LAYER_CORE_DATABASE=_hyperion_core_
SILVER_LAYER_AUDIT_DATABASE=_hyperion_audit_
# Option B default: a fresh engine only has `root`. If you ran hyperion-util's
# bootstrap, switch to the service account it created (hyperion_service).
SERVICE_ACCOUNT_USERNAME=root
SERVICE_ACCOUNT_PASSWORD=
SILVER_LAYER_TRANSACTION=false
ADMIN_ROLE=admin

# ---- Local FHIR (HAPI) ----
FHIR_SERVER_URL=http://hapi-fhir:8080/fhir

# ---- Local-mode pipeline window ----
RESOURCE_TYPES=Patient,Observation,Condition
LOOKBACK_DAYS=30

# ---- FHIR pull tuning ----
NDJSON_FILE_SIZE=1000
FHIR_PULL_MAX_RETRY_COUNT=3
FHIR_SERVER_TIMEOUT_SECONDS=60

# ---- Pool / processing ----
DB_POOL_SIZE=5
PROCESSING_THREADS=4
MESSAGE_BATCH_SIZE=10
CORES_CONVERTER=2
CORES_EXPORTER=2
AUDIT_BATCH_SIZE=100
AUDIT_FLUSH_INTERVAL=30

# ---- Feature flags ----
DEFAULT_META_SOURCE=hyperion-local
IS_AUDIT=false
IS_LINEAGE=false
RETRY_MESSAGE_DELAY_TIME=60

# ---- FHIR exporter / scheduler (Azure mode only) ----
FHIR_EXPORTER_TIME_INTERVAL=60
FHIR_EXPORTER_START_DATE=
FHIR_EXPORTER_END_DATE=
MAX_RUN_CYCLES=1
TIME_RANGE_MULTIPLIER=1

# ============================================================
# Sidecars (admin_grant_manager, root_password_manager,
#           cluster_metadata_exporter, cluster_metadata_restorer)
# Required only if you run these as K8s sidecars against an engine FE pod.
# Not exercised by the local docker-compose stack — leave defaults if you're
# only running the pipeline locally.
# ============================================================
# --- Engine root credentials (separate from SERVICE_ACCOUNT_*; required by sidecars) ---
SILVER_LAYER_ROOT_USERNAME=root
SILVER_LAYER_ROOT_PASSWORD=

# --- FE filesystem paths (mounted from the engine FE pod via shared volume) ---
FE_LOG_PATH=/opt/app/logs
FE_LOG_FILE_PATH=/opt/engine/fe/log/fe.audit.log
FE_META_FOLDER_PATH=/opt/engine/fe/meta
FE_PID_FILE=/opt/engine/fe/bin/fe.pid

# --- Liveness probe touch-file ---
HEALTH_CHECK_FILE=/tmp/admin_grant_manager_healthy

# --- Cron schedules ---
ROOT_PASSWORD_MANAGER_CRON_EXPRESSION=0 */6 * * *

# Encryption salt for the root-password vault blob (properties/.security).
# Generate with: openssl rand -hex 16
# Each deployment must use a unique value. Changing this requires re-encrypting
# the .security blob (decrypt with old salt, re-encrypt with new salt).
ROOT_PASSWORD_MANAGER_SALT=
CLUSTER_METADATA_EXPORTER_CRON_EXPRESSION=0 2 * * *

# --- Metadata export/restore tuning ---
VERIFICATION_THRESHOLD=0.5
METADATA_EXPORTER_UPLOAD_TIMEOUT=600
METADATA_EXPORTER_UPLOAD_WORKERS=16
METADATA_RESTORER_DOWNLOAD_TIMEOUT=600
METADATA_RESTORER_DOWNLOAD_WORKERS=16

# --- Azure Blob container for sidecar utilities (root password vault) ---
AZURE_STORAGE_CONTAINER_UTILITY=

# ============================================================
# Azure mode (uncomment + fill when CLOUD_STORAGE=azure etc.)
# ============================================================
# AZURE_STORAGE_ACCOUNT_CONNECTION_STRING=
# AZURE_STORAGE_ACCOUNT_BASEURL=
# AZURE_STORAGE_ACCOUNT_NAME=
# AZURE_STORAGE_CONTAINER_STAGE=
# AZURE_STORAGE_CONTAINER_FAILURE=
# AZURE_STORAGE_CONTAINER_METADATA_BACKUP=
#
# AZURE_SERVICEBUS_NAMESPACE_CONNECTION_STRING=
# AZURE_SERVICEBUS_EVENT_QUEUE=
# AZURE_SERVICEBUS_BATCH_PARAMETER_QUEUE=
# AZURE_SERVICEBUS_RETRY_QUEUE=
# AZURE_SERVICEBUS_AUDIT_QUEUE=
# AZURE_SERVICEBUS_CORE_SUBSCRIPTION=
# AZURE_SERVICEBUS_TOPIC=
# AZURE_SERVICEBUS_AUDIT_QUEUE_SCHEDULE_INTERVAL=300
#
