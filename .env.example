# Hyperion mono-repo demo — shared environment template
#
# Copy this file to `.env` (which is gitignored) and adjust as needed.
# Defaults below are tuned for the one-command local demo:
#   docker compose up
# which wires every service to the in-network service hostnames
# (starrocks-fe, minio, hapi-fhir, etc.) via compose's `environment:` blocks.
#
# To repoint the same .env at an Azure-managed engine + FHIR, change the
# SILVER_LAYER_*, FHIR_SERVER_URL, and uncomment the Azure block at the end.

# ───────────────── Logging ─────────────────
# INFO | DEBUG | ERROR
LOG_LEVEL=INFO

# ───────────────── Mode switches (per service) ─────────────────
# local | azure — each switch is independent
CLOUD_STORAGE=local
SERVICEBUS=local
FHIR_SERVICE=local
DEPLOYMENT_TYPE=local

# ───────────────── Hyperion Engine (StarRocks shared-data) ─────────────────
SILVER_LAYER_ROOT_USERNAME=root
SILVER_LAYER_ROOT_PASSWORD=
SILVER_LAYER_QUERY_SERVER=starrocks-fe:9030
SILVER_LAYER_HTTP_SERVER=starrocks-fe:8030
SILVER_LAYER_CATALOG=default_catalog
SILVER_LAYER_CORE_DATABASE=_hyperion_core_
SILVER_LAYER_AUDIT_DATABASE=_hyperion_audit_
SILVER_LAYER_REPLICA=1
SILVER_LAYER_STORAGE_VOLUME=hyperion_storage_volume
SILVER_LAYER_TRANSACTION=false
ADMIN_ROLE=admin

# Service-account user created by hyperion-util at bootstrap, then used by
# hyperion-core at runtime. (Local demo: blank password works against a
# fresh StarRocks root.)
SERVICE_ACCOUNT_USERNAME=hyperion_service
SERVICE_ACCOUNT_PASSWORD=

# ───────────────── FHIR server ─────────────────
FHIR_SERVER_URL=http://hapi-fhir:8080/fhir
LOCAL_FHIR_SERVER_TIMEOUT_SECONDS=30
FHIR_SERVER_TIMEOUT_SECONDS=60

# ───────────────── Local-mode storage (MinIO over S3 API) ─────────────────
LOCAL_STORAGE_ENDPOINT=http://minio:9000
LOCAL_STORAGE_LOCATIONS=s3://hyperion/
# Demo-only credentials — change these for any non-local deployment.
LOCAL_STORAGE_ACCESS_KEY_ID=minioadmin
LOCAL_STORAGE_ACCESS_KEY_SECRET=minioadmin123  # MinIO default; safe for local demo only
LOCAL_STORAGE_REGION=us-east-1

# ───────────────── Synthea data generator (parent compose only) ─────────────────
# How many synthetic patients to generate at first compose-up. Each patient
# yields 50-200 FHIR resources (Encounter, Observation, Condition, Procedure,
# MedicationRequest, Immunization, ExplanationOfBenefit, Claim, ...).
# Generation is roughly linear: 10 patients ~60-90s, 100 patients ~5-8 min.
# Disk: ~0.5 MB per patient in the synthea-output volume.
SYNTHEA_PATIENT_COUNT=10

# Fixed seed → deterministic patient set; change to vary the population.
SYNTHEA_SEED=12345

# Synthea version (Maven release tag); jar is downloaded once into a named
# volume so changing this triggers a fresh download on next `up`.
SYNTHEA_VERSION=3.3.0

# Hospital and Practitioner side-bundles. Default true: patient transaction
# bundles reference Organizations and Practitioners via NPI match URLs, so
# HAPI needs those resources loaded first. The synthea-loader stages loads
# in order (hospital → practitioner → patients) to keep references resolvable.
# Set both to false only if you've configured your FHIR server to skip
# reference validation on write.
SYNTHEA_INCLUDE_HOSPITAL=true
SYNTHEA_INCLUDE_PRACTITIONER=true

# Restrict generation to patients alive at simulation end. Set false to also
# include deceased patients (Synthea models full lifespans).
SYNTHEA_ONLY_ALIVE=true

# ───────────────── Pipeline window (core local mode) ─────────────────
# Which FHIR resource types hyperion-core pulls from the FHIR server.
# Synthea generates many more (full list in this directory's README); add to
# this comma-separated list to ingest more — every type in this list must
# have a matching table in _hyperion_core_ (which util generated from the
# FHIR R4 schema, so all standard types are available).
RESOURCE_TYPES=Patient,Observation,Condition,Encounter
LOOKBACK_DAYS=365

# ───────────────── Pipeline tuning ─────────────────
NDJSON_FILE_SIZE=1000
FHIR_PULL_MAX_RETRY_COUNT=3
DB_POOL_SIZE=5
PROCESSING_THREADS=4
MESSAGE_BATCH_SIZE=10
CORES_CONVERTER=2
CORES_EXPORTER=2
AUDIT_BATCH_SIZE=100
AUDIT_FLUSH_INTERVAL=30

# ───────────────── Audit / lineage / observability ─────────────────
DEFAULT_META_SOURCE=hyperion-local
IS_AUDIT=false
IS_LINEAGE=false
RETRY_MESSAGE_DELAY_TIME=60

# ───────────────── Util-specific schema flags ─────────────────
SCHEMA_OVERWRITE_FLAG=true
DATABASE_INITIALIZATION_FLAG=true

# ───────────────── Azure-mode placeholders (uncomment when CLOUD_STORAGE=azure) ─────────────────
# AZURE_FHIR_SERVER_BASEURL=
# AZURE_FHIR_SERVER_CLIENT_ID=
# AZURE_FHIR_SERVER_CLIENT_SECRET=
# AZURE_FHIR_SERVER_SCOPE=
# AZURE_FHIR_SERVER_GRANT_TYPE=client_credentials
# AZURE_FHIR_SERVER_TOKEN_URL=
# AZURE_FHIR_SERVER_TIMEOUT_SECONDS=60
#
# Engine table-data storage (backs StarRocks shared-data tablets):
# AZURE_BLOB_STORAGE_SILVER_LAYER_CONTAINER=
# Endpoint suffix MUST match AZURE_BLOB_STORAGE_VERSION:
#   version=1 (AZBLOB) → .blob.core.windows.net
#   version=2 (ADLS2)  → .dfs.core.windows.net
# Mismatch causes silent CREATE TABLE failure on tablet allocation.
# AZURE_BLOB_STORAGE_END_POINT=
# AZURE_BLOB_STORAGE_VERSION=2
# AZURE_BLOB_STORAGE_ACCOUNT_KEY=
#
# AZURE_STORAGE_ACCOUNT_CONNECTION_STRING=
# AZURE_STORAGE_ACCOUNT_BASEURL=
# AZURE_STORAGE_ACCOUNT_NAME=
# AZURE_STORAGE_CONTAINER_STAGE=
# AZURE_STORAGE_CONTAINER_FAILURE=
#
# AZURE_SERVICEBUS_NAMESPACE_CONNECTION_STRING=
# AZURE_SERVICEBUS_EVENT_QUEUE=
# AZURE_SERVICEBUS_BATCH_PARAMETER_QUEUE=
# AZURE_SERVICEBUS_RETRY_QUEUE=
# AZURE_SERVICEBUS_AUDIT_QUEUE=
# AZURE_SERVICEBUS_TOPIC=